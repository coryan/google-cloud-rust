    /// Creates a new {{NameToPascal}} client configured with [config].
    pub async fn new_with_config(conf: crate::ConfigBuilder) -> Result<crate::{{NameToPascal}}> {
        let tracing = Self::tracing_enabled(&conf);
        let client = crate::transport::{{NameToPascal}}::new(conf).await?;
        if tracing {
